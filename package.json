{
  "name": "mmd-js",
  "version": "0.4.0-alpha.0",
  "type": "module",
  "description": "",
  "main": "index.js",
  "homepage": "https://mmd-js.vercel.app",
  "repository": "github:anulman/mmd-js",
  "engines": {
    "node": "24.x"
  },
  "scripts": {
    "install": "node scripts/check-napi-prebuild.mjs || exit 0",
    "build:napi": "npm run prebuild:napi",
    "build:wasm": "npm run wasm:build",
    "build:js": "tsc -p . --noEmit false",
    "build": "concurrently --kill-others-on-fail -s all \"npm:build:napi\" \"npm:build:wasm\" \"npm:build:js\"",
    "test": "cp -f build/wasm/packages/wasm/mmd.js mmd.wasm.js && cp -f build/wasm/packages/wasm/mmd.wasm mmd.wasm && node --test tests/*.test.mjs",
    "test:update-snapshots": "node --test tests/mmd7-integrated.test.mjs",
    "demo:bin": "ts-node bin/demo.ts",
    "demo:web": "npm -C demo run dev",
    "napi:compile": "cmake-js compile -O build/napi",
    "wasm:configure": "emcmake cmake -B build/wasm",
    "wasm:build": "emmake make -C build/wasm",
    "prepare:package": "npm run build:js && npm run prebuild:napi && npm run wasm:configure && npm run build:wasm && cp -f build/wasm/packages/wasm/mmd.wasm mmd.wasm && cp -f build/wasm/packages/wasm/mmd.js mmd.wasm.js",
    "prepack": "npm run prepare:package",
    "prepublishOnly": "npm run prepare:package && npm run package:smoke",
    "package:smoke": "node tests/package-smoke.mjs",
    "prebuild:napi": "npm run napi:compile && node scripts/copy-napi-prebuild.mjs",
    "prebuild": "npm run prepare:package"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "cmake-js": "^7.2.1",
    "node-addon-api": "^6.1.0",
    "node-gyp-build": "^4.8.4"
  },
  "devDependencies": {
    "@swc/core": "^1.3.56",
    "@types/bindings": "^1.5.1",
    "@types/fs-extra": "^11.0.1",
    "@types/lodash": "^4.14.194",
    "@types/node": "^20.2.1",
    "commander": "^10.0.1",
    "concurrently": "^8.0.1",
    "fs-extra": "^11.1.1",
    "lodash": "^4.17.21",
    "prettier": "^2.8.8",
    "trim-buffer": "^5.0.0",
    "ts-node": "^10.9.1",
    "typescript": "^5.0.4"
  },
  "types": "index.d.ts",
  "files": [
    "LICENSE.md",
    "README.md",
    "index.js",
    "index.d.ts",
    "types.js",
    "types.d.ts",
    "wasm.js",
    "wasm.d.ts",
    "mmd.wasm",
    "mmd.wasm.js",
    "mmd.wasm.d.ts",
    "scripts/check-napi-prebuild.mjs",
    "prebuilds/**"
  ]
}
