%
%	Core LaTeX package for MultiMarkdown 7 feature support
%

% Options:
%	[showtoc] -- Include TOC at the beginning of the document
%	[notoc] -- Do not include TOC at the beginning of the document

% Useful "variables"

%	Defined by MultiMarkdown metadata (or by LaTeX code):
%	\mytitle
%	\myauthor
%	\mydate
%	\mykeywords
%	\subtitle
%	\affiliation


\ProvidesPackage{mmd7-core}


% Base packages to use
\@ifclassloaded{sffms}{}{
	\usepackage{hyperref}				% Must preceed glossaries
}

\@ifclassloaded{memoir}{
	\usepackage{memhfixc}				% Fix error with hyperref and memoir class
}{}

\usepackage[acronym]{glossaries}    % Support glossary entries
\usepackage{fancyvrb}				% Allow \verbatim et al. in footnotes
\usepackage{graphicx}				% Enable images
\usepackage{booktabs}				% Better tables
\usepackage{tabulary}				% Support longer table cells

\@ifclassloaded{ltx-talk}{}{		% Seems to interfere with font selection in ltx-talk
	\usepackage[T1]{fontenc}		% Use T1 font encoding for accented characters (e.g. <> in verbatim)
}

\usepackage[utf8]{inputenc}			% For UTF-8 support
\usepackage{xcolor}					% Allow for color (annotations)
\usepackage{listings}				% Allow for source code highlighting
\usepackage{lipsum}					% For generating sample text for testing

% NOTE: Loading natbib with these options silences warnings for basic MMD citations
% If you are using BibTeX, you'll need to change this
\@ifclassloaded{tufte-handout}{}{
	\@ifclassloaded{tufte-book}{}{
		\@ifclassloaded{letter}{}{
			\@ifclassloaded{ltx-talk}{}{
				\usepackage[sort&compress,numbers]{natbib}	% Better bibliography support
			}
		}
	}
}

\@ifclassloaded{sffms}{}{
	\usepackage[normalem]{ulem}			% Support strikethrough
}


% Packages to support CriticMarkup
\usepackage{soul}
\usepackage{xargs}
\usepackage{todonotes}
\@ifclassloaded{beamer}{
	\presetkeys{todonotes}{inline}{}    % We need inline notes in Beamer
}{}
\newcommandx{\cmnote}[2][1=]{\linespread{1.0}\todo[linecolor=red,backgroundcolor=red!25,bordercolor=red,#1]{#2}}

% Use \ul instead of \underline since we are using soul
\let\underline\ul


% Configure glossary
\glstoctrue	% Show Glossaries in the TOC
\makeglossaries
\makeindex


% Fill in missing metadata
\ifx\mytitle\undefined
	\def\mytitle{Title}
\fi

\ifx\myauthor\undefined
	\def\myauthor{Author}
\fi

\ifx\mydate\undefined
	\def\mydate{\today}
\else
	\date{\mydate}
\fi

\ifx\mykeywords\undefined
	\def\mykeywords{}
\fi


% Use basic metadata
\@ifclassloaded{sffms}{
	\title{\mytitle}
	\runningtitle{\mytitle}
	\author{\myauthor}
	\surname{\myauthor}
}{
	\title{\mytitle}
	\author{\myauthor}
}


% Ignore other options
\DeclareOption{showtoc}{
	\def\showtoc{true}
}

\DeclareOption{notoc}{
	\def\notoc{true}
}

\DeclareOption*{}

\ProcessOptions


\@ifclassloaded{ltx-talk}{}{
	\@ifclassloaded{beamer}{}{
		% Special commands for other classes besides Beamer and ltx-talk

		% Use document metadata to configure hyperref (Beamer already does this)
		\@ifclassloaded{sffms}{
			% This doesn't work with sffms
		}{
			\hypersetup{
				plainpages=false,
				pdfpagelabels,
				pdftitle={\mytitle},
				pagebackref,
				pdfauthor={\myauthor},
				pdfkeywords={\mykeywords}	
			}
		}

		\@ifclassloaded{letter}{
			% These don't work with letters
		}{
			\@ifclassloaded{sffms}{
			% Or sffms
			}{
				% Start with a title
				\AtBeginDocument{
					\maketitle

					% Show table of contents at the beginning of the document
					\ifx\showtoc\undefined
					\else
						\ifx\notoc\undefined
							\tableofcontents
							\ifboolexpr{
								test {\@ifclassloaded{tufte-book}}
									% or
							}{
								\clearpage
							}{}
						\fi
					\fi
				}
			}
		}
	}
}
