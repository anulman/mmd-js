%
%	Handle options
%

% Configure letter for printing, rather than PDF, and generate envelopes
\DeclareOption{printed}{
	\def\enableprintingenvelope{true}
	% Change PDF page size to match envelope size
	\AtBeginLabels{\eject \pdfpagewidth=\EnvelopeHeight \pdfpageheight=\EnvelopeWidth}
}


% Support additional instructions for a cover page
\DeclareOption{usecoverpage}{
	\def\enablecoverpage{true}
}

% Ignore other options
\DeclareOption*{}

\ProcessOptions


% Generate envelope if appropriate	
\ifx\enableprintingenvelope\undefined
\else
	\makelabels
\fi


%
% Handle letter initialization and finalization
%

% Don't use empty lines -- they take up space in the document for some reason
\AtBeginDocument{
	% Change topmargin for first page
	\ifx\firstpagetopmargin\undefined
	\else
		\newgeometry{top=\firstpagetopmargin,left=1.0in,right=1.0in,bottom=1.0in}
	\fi
	\begin{letter}{\recipient \\ \recipientaddress}
	% Use coverpage content if specified
	\ifx\enablecoverpage\undefined \else \ifx\coverpage\undefined \else \coverpage \fi \fi
	\ifx\salutation\undefined \opening{\recipient,} \else \opening{\salutation} \fi
	% Example for placing a logo
	% \begin{tikzpicture}[remember picture, overlay]
	% 	\node[anchor=north west, shift={(0.5in,-0.675in)}] at (current page.north west) {
	% 		\resizebox{1.5in}{!}{\includegraphics[decodearray={0.2 0.5}]{logo.pdf}}
	% 	};
	% \end{tikzpicture}
	% Restore original margins
	\ifx\firstpagetopmargin\undefined \else \afterpage{\aftergroup\restoregeometry} \fi
}


% Handle letter finalization
\AtEndDocument{
	\ifx\mysignature\undefined
		\signature{\myauthor}
	\else
		\signature{\mysignature}
	\fi
	\closing{Sincerely,}
	\end{letter}
}
