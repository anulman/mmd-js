<?xml version="1.0" encoding="utf-8"?>
<opml version="1.0">
	<head><title>Link Labels</title></head>
	<body>
		<outline text="&gt;&gt;Preamble&lt;&lt;" _note="&#10;[foo].&#10;[ foo].&#10;[foo ].&#10;[ foo ].&#10;&#10;[bar].&#10;[ bar].&#10;[bar ].&#10;[ bar ].&#10;&#10;[baz].&#10;[ baz].&#10;[baz ].&#10;[ baz ].&#10;&#10;[foo bar].&#10;[ foo bar].&#10;[foo bar ].&#10;[ foo bar ].&#10;&#10;[foobar].&#10;[ foobar].&#10;[foobar ].&#10;[ foobar ].&#10;&#10;[ foo]: http://foo.com/&#10;[bar ]: http://bar.com/&#10;[ baz ]: http://baz.com/&#10;[foo bar]: http://foobar.com/&#10;"/>
		<outline text="&gt;&gt;Metadata&lt;&lt;">
			<outline text="title" _note="Link Labels"/>
			<outline text="latexconfig" _note="article"/>
		</outline>
	</body>
</opml>
